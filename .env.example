# Sao chep file nay thanh .env va dien thong tin that

# Cong chay server
PORT=3000

# ===== DISCORD (kenh thong bao chinh) =====
# Cach lay: Discord > chon Server > Server Settings > Integrations >
#   Webhooks > New Webhook > chon kenh > Copy Webhook URL
# Dan link day vao day (dang https://discord.com/api/webhooks/....)
DISCORD_WEBHOOK_URL=

# ===== ANH SAN PHAM TRONG NOTI =====
# Dia chi cong khai cua web de Discord tai duoc anh (vd khi deploy public).
# De trong neu chay localhost (anh se khong hien tren Discord).
PUBLIC_BASE_URL=

# ===== EMAIL (TUY CHON - de trong neu chi dung Discord) =====
ORDER_EMAIL_TO=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=LnD clozet
